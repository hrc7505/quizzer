generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phoneNumber   String?   @unique
  role          String    @default("USER") // "USER" or "ADMIN"
  accounts      Account[]
  sessions      Session[]
  attempts      QuizAttempt[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models

model Exam {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  topics      Topic[]  @relation("ExamTopics")
}

model Topic {
  id           String     @id @default(uuid())
  title        String
  description  String?
  createdAt    DateTime   @default(now())
  
  exams        Exam[]     @relation("ExamTopics")
  parentTopics Topic[]    @relation("TopicHierarchy")
  subtopics    Topic[]    @relation("TopicHierarchy")

  quizzes      Quiz[]     @relation("TopicQuizzes")
  questions    Question[]
}

model Quiz {
  id          String        @id @default(uuid())
  title       String
  difficulty  String        @default("Medium") // "Easy", "Medium", "Hard"
  quizOrder   Int
  topics      Topic[]       @relation("TopicQuizzes")
  questions   Question[]
  attempts    QuizAttempt[]
}

model Question {
  id            String   @id @default(uuid())
  topicId       String
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  quizId        String?
  quiz          Quiz?    @relation(fields: [quizId], references: [id], onDelete: SetNull)
  text          String
  options       String[]
  correctAnswer String
  hint          String
  description   String
  elaboration   String?  @db.Text
}

model QuizAttempt {
  id              String       @id @default(uuid())
  quizId          String
  quiz            Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scorePercentage Float        @default(0.0)
  correctCount    Int          @default(0)
  wrongCount      Int          @default(0)
  timeTakenSec    Int          @default(0)
  completed       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  answers         UserAnswer[]
}

model UserAnswer {
  id             String      @id @default(uuid())
  attemptId      String
  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
}
