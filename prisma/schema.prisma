generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  phoneNumber   String?       @unique
  role          String        @default("USER")
  accounts      Account[]
  attempts      QuizAttempt[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Exam {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  topics      Topic[]  @relation("ExamTopics")
}

model Topic {
  id          String     @id @default(uuid())
  title       String
  createdAt   DateTime   @default(now())
  description String?
  questions   Question[]
  exams       Exam[]     @relation("ExamTopics")
  Topic_A     Topic[]    @relation("TopicHierarchy")
  Topic_B     Topic[]    @relation("TopicHierarchy")
  quizzes     Quiz[]     @relation("TopicQuizzes")
}

model Quiz {
  id         String        @id @default(uuid())
  title      String
  quizOrder  Int
  difficulty String        @default("Medium")
  questions  Question[]
  attempts   QuizAttempt[]
  topics     Topic[]       @relation("TopicQuizzes")
}

model Question {
  id            String   @id @default(uuid())
  topicId       String
  quizId        String?
  text          String
  options       String[]
  correctAnswer String
  hint          String
  description   String
  elaboration   String?
  quiz          Quiz?    @relation(fields: [quizId], references: [id])
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id              String       @id @default(uuid())
  quizId          String
  scorePercentage Float        @default(0.0)
  correctCount    Int          @default(0)
  wrongCount      Int          @default(0)
  timeTakenSec    Int          @default(0)
  createdAt       DateTime     @default(now())
  completed       Boolean      @default(false)
  userId          String?
  quiz            Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers         UserAnswer[]
}

model UserAnswer {
  id             String      @id @default(uuid())
  attemptId      String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}
